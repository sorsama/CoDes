{
  "name": "codes",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source desktop workspace for running coding-agent CLIs side by side",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "relay:dev": "npm run dev --workspace @codes/signaling",
    "relay:start": "npm run start --workspace @codes/signaling",
    "preview": "vite preview",
    "tauri": "node scripts/tauri.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/geist-mono": "^5.3.0",
    "@fontsource/instrument-sans": "^5.3.0",
    "@fontsource/material-symbols-rounded": "^5.3.0",
    "@tanstack/react-query": "^5.101.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.4",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
